# ─── Smart FinTech Assistant: Environment Template ───
# Copy this file to .env and fill in your actual credentials.

# Google Gemini AI: Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Configuration: Default for local development
REDIS_URL=redis://localhost:6379/0

# Security: Generate a secure random string for JWT/Sessions
SECRET_KEY=generate_a_secure_random_string_here
